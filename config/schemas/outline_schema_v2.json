{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "ContentOutline",
	"description": "Content outline structure for video generation",
	"type": "object",
	"properties": {
		"title": {
			"type": "string"
		},
		"hook": {
			"type": "string"
		},
		"sections": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"heading": {
						"type": "string"
					},
					"points": {
						"type": "array",
						"items": {
							"type": "string"
						}
					}
				},
				"required": ["heading", "points"]
			}
		},
		"conclusion": {
			"type": "string"
		},
		"cta": {
			"type": "string"
		}
	},
	"required": ["title", "hook", "sections", "conclusion"]
}
