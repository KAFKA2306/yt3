{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "ResearchLlmResponse",
	"description": "Output from research agent with director data and news",
	"type": "object",
	"properties": {
		"director_data": {
			"type": "object",
			"properties": {
				"angle": {
					"type": "string"
				},
				"tone": {
					"type": "string"
				},
				"target_audience": {
					"type": "string"
				}
			},
			"required": ["angle", "tone"]
		},
		"news": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"title": {
						"type": "string"
					},
					"description": {
						"type": "string"
					},
					"source": {
						"type": "string"
					},
					"url": {
						"type": "string"
					},
					"published_at": {
						"type": "string"
					}
				},
				"required": ["title", "description", "source"]
			}
		}
	},
	"required": ["director_data", "news"]
}
